{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "HNW_ENABLE_OPENMP": "ON",
        "HNW_ENABLE_OMP_SIMD": "OFF",
        "HNW_ENABLE_LTO": "OFF",
        "HNW_ENABLE_MARCH_NATIVE": "OFF",
        "HNW_ENABLE_CUDA": "OFF"
      }
    },
    {
      "name": "linux-gcc-debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-gcc",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-clang",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-gcc-cuda",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "HNW_ENABLE_CUDA": "ON"
      }
    },
    {
      "name": "macos-clang",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "HNW_ENABLE_CUDA": "OFF"
      }
    },
    {
      "name": "windows-msvc",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "HNW_ENABLE_CUDA": "OFF"
      }
    },
    {
      "name": "windows-msvc-cuda",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "HNW_ENABLE_CUDA": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-gcc-debug",
      "configurePreset": "linux-gcc-debug"
    },
    {
      "name": "linux-gcc",
      "configurePreset": "linux-gcc"
    },
    {
      "name": "linux-clang",
      "configurePreset": "linux-clang"
    },
    {
      "name": "linux-gcc-cuda",
      "configurePreset": "linux-gcc-cuda"
    },
    {
      "name": "macos-clang",
      "configurePreset": "macos-clang"
    },
    {
      "name": "windows-msvc",
      "configurePreset": "windows-msvc"
    },
    {
      "name": "windows-msvc-cuda",
      "configurePreset": "windows-msvc-cuda"
    }
  ]
}
